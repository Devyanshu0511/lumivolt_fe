# Ignore all .log files
*.log

# Ignore a specific file
config/secrets.json

# Ignore entire directory
node_modules/
dist/
build/

# Ignore OS-generated files
.DS_Store
Thumbs.db
# AppleDouble sidecars (macOS on ExFAT/FAT32/USB — metadata, not source)
._*

# Ignore Python cache
__pycache__/
*.pyc

# Ignore local env file (but keep template)
# .env
# !.env.example